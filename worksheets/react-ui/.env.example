# AI teacher configuration.
#
# Copy to .env.local for local development (gitignored), and set the same values
# in Vercel -> Project -> Settings -> Environment Variables.
#
# NOTE: only the LAST variable uses the REACT_APP_ prefix, and that is
# deliberate. Create React App substitutes REACT_APP_* values into the public JS
# bundle at build time, so anything with that prefix is readable by anyone who
# opens devtools. The API key must NEVER have it.

# --- Provider (any OpenAI-compatible /chat/completions endpoint) -------------
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-replace-me

# Verified available on OpenRouter. Roughly $0.23/M input, $0.73/M output -
# about $0.0002 per graded answer and $0.0006 per chat turn.
AI_MODEL=z-ai/glm-5.2

# Optional: point grading at a different model. Falls back to AI_MODEL.
# AI_MODEL_GRADER=

# Set to 0 if the chosen model rejects response_format: {type:"json_object"}.
# (The code already retries once without it, so this is just a fast path.)
AI_SUPPORTS_JSON_MODE=1

# Reasoning models (glm-5.2 included) spend max_tokens on hidden reasoning
# BEFORE writing any answer. At these small caps that silently ate the entire
# budget and returned empty content, which looks identical to a broken key.
# Leave this unset/1 to switch reasoning off: neither grading nor a short chat
# reply benefits from it, and it measured ~9x cheaper. Set to 0 to re-enable.
AI_DISABLE_REASONING=1

# Optional OpenRouter attribution headers - shown on openrouter.ai rankings.
AI_APP_URL=http://localhost:3000
AI_APP_TITLE=Python Adventures for Kids

# --- Access control ---------------------------------------------------------
# The shared family password. This is the control that actually stops a stranger
# who finds the endpoint URL, because it never ships in the JS bundle - the kids
# type it once and it is stored in their browser. Rotate by editing this value.
AI_FAMILY_PASSPHRASE=change-me

# Comma-separated. Add your Vercel URL before deploying.
AI_ALLOWED_ORIGINS=http://localhost:3000

# --- Cost caps --------------------------------------------------------------
AI_MAX_TOKENS_CHAT=300
AI_MAX_TOKENS_GRADE=160

# Request timeouts. A conversational reply takes meaningfully longer than a
# one-word grading verdict; too tight a chat timeout is what produces the
# "I'm having a little nap" fallback. Both stay under vercel.json's maxDuration.
AI_TIMEOUT_CHAT_MS=25000
AI_TIMEOUT_GRADE_MS=15000

# --- Client feature flag (safe to expose - it is only a boolean) ------------
REACT_APP_AI_ENABLED=1

# --- Parent monitoring (optional) -------------------------------------------
# Turns on the browser-side telemetry that feeds the parent dashboard. Safe to
# expose - it is only a boolean, like REACT_APP_AI_ENABLED. With it unset/0, no
# events are collected and the app behaves exactly as before.
REACT_APP_TELEMETRY_ENABLED=1

# Supabase project the backend writes events to and the dashboard reads from.
# The service_role key bypasses row-level security, so it is SERVER-ONLY and must
# NEVER carry a REACT_APP_ prefix. Find both under Supabase -> Project Settings
# -> API. Run db/schema.sql once in the Supabase SQL editor to create the table.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=replace-me-server-only

# Separate secret that gates the /parent dashboard read endpoint. The kids must
# NOT know this - it is different from AI_FAMILY_PASSPHRASE. Fails closed: if it
# is unset, /api/parent refuses to serve rather than expose the kids' data.
PARENT_PIN=change-me-parents-only

# NOTE: telemetry ingest (/api/track) reuses AI_FAMILY_PASSPHRASE above as its
# write gate, so set that too. The kids enter it once (the AI teacher panel is
# where they type it); after that, telemetry flushes automatically.
