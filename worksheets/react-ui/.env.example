# AI teacher configuration.
#
# Copy to .env.local for local development (gitignored), and set the same values
# in Vercel -> Project -> Settings -> Environment Variables.
#
# NOTE: only the LAST variable uses the REACT_APP_ prefix, and that is
# deliberate. Create React App substitutes REACT_APP_* values into the public JS
# bundle at build time, so anything with that prefix is readable by anyone who
# opens devtools. The API key must NEVER have it.

# --- Provider (any OpenAI-compatible /chat/completions endpoint) -------------
AI_BASE_URL=https://openrouter.ai/api/v1
AI_API_KEY=sk-or-v1-replace-me

# Verified available on OpenRouter. Roughly $0.23/M input, $0.73/M output -
# about $0.0002 per graded answer and $0.0006 per chat turn.
AI_MODEL=z-ai/glm-5.2

# Optional: point grading at a different model. Falls back to AI_MODEL.
# AI_MODEL_GRADER=

# Set to 0 if the chosen model rejects response_format: {type:"json_object"}.
# (The code already retries once without it, so this is just a fast path.)
AI_SUPPORTS_JSON_MODE=1

# Optional OpenRouter attribution headers - shown on openrouter.ai rankings.
AI_APP_URL=http://localhost:3000
AI_APP_TITLE=Python Adventures for Kids

# --- Access control ---------------------------------------------------------
# The shared family password. This is the control that actually stops a stranger
# who finds the endpoint URL, because it never ships in the JS bundle - the kids
# type it once and it is stored in their browser. Rotate by editing this value.
AI_FAMILY_PASSPHRASE=change-me

# Comma-separated. Add your Vercel URL before deploying.
AI_ALLOWED_ORIGINS=http://localhost:3000

# --- Cost caps --------------------------------------------------------------
AI_MAX_TOKENS_CHAT=300
AI_MAX_TOKENS_GRADE=160

# --- Client feature flag (safe to expose - it is only a boolean) ------------
REACT_APP_AI_ENABLED=1
